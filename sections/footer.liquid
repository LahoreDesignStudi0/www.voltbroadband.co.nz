<!-- Footer CSS -->
<style>
  *{
      margin-top: 0;
  }
  .footer {
      background-color: #EF3124;
      color: white;
      padding-top: 100px;
      padding-bottom: 20px;
  }
  /* Top Section: Two Columns */
  #footer_top {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      gap: 20px;
      margin-bottom: 70px;
  }

  .footer_top_col_left,
  .footer_top_col_right {
      flex: 1 1 45%; /* Two equal-width columns */
      min-width: 300px;
  }
  .footer_top_col_right form {
      display: flex;
      flex-direction: column;
  }
  .footer_top_col_right form input,
  .footer_top_col_right form textarea {
      width: 100%;
      padding: 10px;
      margin-bottom: 15px;
      border-radius: 4px;
      background: no-repeat;
      color: white;
      border: 1px solid #336FB4;
      box-sizing: border-box;
      font-size: 18px;
  }
  .footer_top_col_right form ::placeholder{
      color: #2193D8 !important;
  }
  .footer_top_col_right form textarea {
      resize: none;
      height: 80px;
  }

  .footer_top_col_right form button {
      background-color: #2193D8;
      border: none;
      padding: 10px 20px;
      border-radius: 4px;
      cursor: pointer;
      font-size: 18px;
      align-self: flex-end;
      color: #034EA2;
      transition: 0.3s;
  }

  .footer_top_col_right form button:hover {
      color: white;
      box-shadow: 0 0 10px -5px white;
  }

  /* Middle Section: Links and Social Icons */
  #footer_middle {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: center;
      gap: 20px;
      margin-bottom: 80px;
  }

  .footer-links {
      display: flex;
      gap: 20px;
  }

  .footer-links a {
      text-decoration: none;
      color: white;
      font-weight: 600;
      font-size: 15px;
  }

  .social-icons {
      display: flex;
      gap: 15px;
  }

  .social-icons a {
      text-decoration: none;
      color: white;
      font-size: 1.2rem;
  }

  /* Bottom Section: Copyright */
  #footer_bottom {
      font-size: 14px;
      color: rgba(255, 255, 255, 0.7);
  }
  .social_icons {
      display: flex;
      align-items: center;
      gap: 50px;
  }
  .social_icons_list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: inline-flex;
      align-items: center;
      gap: 30px;
  }
  .social_icons_list_item_icon {
      width: 40px;
      height: auto;
  }
  .footer_logo_img{
    width: 120px;
    height: auto;
  }
  .footer_logo {
  	margin-bottom: 20px;
  }
  .copyright {
      margin: 0;
    font-size: 16px !important;
  }
  .footer_top_col_left_heading {
      color: white !important;
      font-size: 40px !important;
      margin-bottom: 10px;
      font-weight: 700;
  }
  .footer_top_col_left_desc {
      color: white !important;
      font-size: 1.8rem !important;
  }
  /* Responsive Design */
  @media (max-width: 768px) {
      #footer_top {
          flex-direction: column;
          align-items: center;
      }

      .footer_top_col_left,
      .footer_top_col_right {
          flex: 1 1 100%;
      }

      #footer_middle {
          flex-direction: column;
          text-align: center;
      }
  }
</style>

